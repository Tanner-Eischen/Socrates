# Runtime
NODE_ENV=development
PORT=3333
HOST=0.0.0.0

# Security
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me
SESSION_SECRET=change-me
DEV_AUTH_BYPASS=false

# OpenAI
OPENAI_API_KEY=
OPENAI_ORGANIZATION=

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=socrates
DB_USER=postgres
DB_PASSWORD=password
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=10000
DB_SSL=false

# Optional: Use in-memory database for quick local testing without PostgreSQL
# Uncomment the line below to skip database setup - great for quick demos!
# DB_INMEM=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=socrates:

# CORS
# Use comma-separated origins in production, e.g. https://app.example.com,https://www.example.com
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=info
